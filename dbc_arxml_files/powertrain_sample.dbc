VAL_ 256 EngineStatus 0 "Off" 1 "Cranking" 2 "Running" 3 "Error";
VAL_ 256 MIL_Active 0 "Off" 1 "On";
VAL_ 256 CheckEngine 0 "OK" 1 "Fault";
VAL_ 512 ABSActive 0 "Inactive" 1 "Active";
VAL_ 512 TCSActive 0 "Inactive" 1 "Active";
VAL_ 768 GearPosition 0 "Park" 1 "1st" 2 "2nd" 3 "3rd" 4 "4th" 5 "5th" 6 "6th" 7 "Reverse" 8 "Neutral";
VAL_ 768 TransmissionMode 0 "Auto" 1 "Sport" 2 "Manual" 3 "Winter" 4 "ECO";
VAL_ 1024 ParkingBrake 0 "Released" 1 "Applied";
VAL_ 1536 ACCompressor 0 "Off" 1 "On";
VAL_ 1536 RecirculationMode 0 "Fresh_Air" 1 "Recirculate";
VAL_ 1792 ServiceDue 0 "OK" 1 "Service_Due";
