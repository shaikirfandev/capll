CM_ BU_ Engine_ECU "Engine Control Module - Manages fuel injection, ignition timing, and torque";
CM_ BU_ ABS_ECU "Anti-lock Braking System ECU - Wheel speed monitoring and ABS/TCS control";
CM_ BU_ Transmission_ECU "Transmission Control Module - Gear selection and shift logic";
CM_ BU_ BCM "Body Control Module - Climate, lighting, and body electronics";
CM_ BU_ Gateway "Central gateway - Routes messages between network segments";
CM_ BU_ Cluster "Instrument cluster - Displays vehicle information";

CM_ BO_ 256 "Engine operational data broadcast at 10ms cycle";
CM_ BO_ 512 "Vehicle speed and wheel speed data at 10ms cycle";
CM_ BO_ 768 "Transmission state data at 20ms cycle";
CM_ BO_ 1024 "Brake system data at 10ms cycle";
CM_ BO_ 1280 "Fuel system data at 100ms cycle";
CM_ BO_ 1536 "Climate control data at 200ms cycle";
CM_ BO_ 1792 "Diagnostics and maintenance data at 1000ms cycle";
CM_ BO_ 2048 "Gateway alive counter at 10ms cycle";

CM_ SG_ 256 EngineSpeed "Engine rotational speed in RPM. Range: 0-8191.75 RPM, Factor: 0.25";
CM_ SG_ 256 EngineStatus "0=Off, 1=Cranking, 2=Running, 3=Error";
CM_ SG_ 512 VehicleSpeed "Calculated vehicle speed in km/h. Factor: 0.1";
CM_ SG_ 768 GearPosition "0=Park, 1-6=Drive gears, 7=Reverse, 8=Neutral";
CM_ SG_ 1024 BrakePressure "Hydraulic brake circuit pressure in bar";

