// ===== HELPER FUNCTIONS =====

void DisplayHelpOnStartup() {
  Write("╔════════════════════════════════════════════════════╗");
  Write("║             KEYBOARD COMMANDS                      ║");
  Write("╚════════════════════════════════════════════════════╝");
  Write("");
  Write("H - Display this help menu");
  Write("S - Display statistics");
  Write("M - Send test message (cascading events)");
  Write("T - Start one-time timer");
  Write("R - Reset all counters");
  Write("C - Show current state");
  Write("? - Show event information");
  Write("");
}

void DisplayHelpMenu() {
  Write("");
  Write("╔════════════════════════════════════════════════════╗");
  Write("║           KEYBOARD HELP MENU                       ║");
  Write("╚════════════════════════════════════════════════════╝");
  Write("");
  
  Write("COMMAND KEYS:");
  Write("─────────────────────────────────────");
  Write("H - Show this help menu");
  Write("S - Show statistics (messages, errors, etc.)");
  Write("M - Send test message (to demonstrate cascading)");
  Write("T - Start a one-time timer (3 second delay)");
  Write("R - Reset all counters to zero");
  Write("C - Show current system state");
  Write("? - Show event handler information");
  Write("");
  
  Write("WHAT TO TRY:");
  Write("─────────────────────────────────────");
  Write("1. Press 'M' to send a message and see multiple");
  Write("   event handlers triggered automatically");
  Write("2. Press 'T' then wait to see a timer event");
  Write("3. Press 'S' repeatedly to see counters change");
  Write("4. Observe the pattern of recurring timers");
  Write("");
}
